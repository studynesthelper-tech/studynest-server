# StudyNest Server — Environment Variables
# Copy this file to .env and fill in your values

# ── Required ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ── AI Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # Required for Claude
OPENAI_API_KEY=sk-...          # Optional, for ChatGPT model
DEEPSEEK_API_KEY=sk-...        # Optional, for DeepSeek model

# ── Quota settings (all optional — defaults shown) ───────────
FREE_QUESTIONS=20              # How many questions free users get per reset period
PREMIUM_QUESTIONS=999          # How many questions premium users get (999 = unlimited)
RESET_DAYS=7                   # How many days before quota resets (7 = weekly)

# Examples:
# FREE_QUESTIONS=5             → Very strict (5/week free)
# FREE_QUESTIONS=50            → Generous (50/week free)
# FREE_QUESTIONS=100           → Very generous (100/week free)
# PREMIUM_QUESTIONS=500        → 500/week premium cap (to protect your bill)
# PREMIUM_QUESTIONS=999        → Effectively unlimited premium
# RESET_DAYS=1                 → Daily reset (more generous for users)
# RESET_DAYS=30                → Monthly reset (stricter)

# ── Server ───────────────────────────────────────────────────
PORT=3000
WEBSITE_URL=https://yourdomain.com   # optional, for CORS whitelist
